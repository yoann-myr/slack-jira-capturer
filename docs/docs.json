{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Slack-to-Jira Capturer",
  "colors": {
    "primary": "#FA6837",
    "light": "#FA8A65",
    "dark": "#541E16"
  },
  "fonts": {
    "heading": {
      "family": "Epilogue",
      "source": "https://fonts.googleapis.com/css2?family=Epilogue:wght@400;600;700&display=swap"
    },
    "body": {
      "family": "Roboto",
      "source": "https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "index",
          "running"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reactions",
          "troubleshooting"
        ]
      },
      {
        "group": "Documentations",
        "pages": [
          "test-docs"
        ]
      },
      {
        "group": "Release-Notes",
        "pages": [
          "2026_4",
          "mars-2026",
          "2026-02"
        ]
      },
      {
        "group": "Evaluation",
        "pages": [
          "evaluation/index",
          "evaluation/baseline-performance"
        ],
        "hidden": true
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/yoann-myr/slack-jira-capturer"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/yoann-myr/slack-jira-capturer"
    }
  }
}
